---
// Import blog posts
const posts = await getCollection('blog'); // Ensure you have a collection of blog posts
---

<html>
<head>
  <title>Blog - My Awesome Blog</title>
  <link rel="stylesheet" href="/styles/blog.css">
</head>
<body>
  <header>
    <h1>Blog</h1>
    <p>Welcome to our blog! Here are our latest posts:</p>
  </header>
  <main>
    <ul>
      {posts.map(post => (
        <li>
          <h2><a href={`/blog/${post.slug}`}>{post.title}</a></h2>
          <p>Published on: {post.date}</p>
          <p>{post.excerpt}</p>
        </li>
      ))}
    </ul>
  </main>
  <footer>
    <p>© 2026 My Awesome Blog</p>
  </footer>
</body>
</html>
